# Mothership — environment variables
# Copy to `.env.local` and fill in. None are required for Phase 1 (static).

# --- AI lead qualification (Phase 5) ---
# OpenAI Responses API — scores inbound leads server-side.
OPENAI_API_KEY=

# n8n webhook — CRM sync for qualified / warm / nurture leads.
N8N_WEBHOOK_URL=

# --- Email (Phase 5) ---
# Resend — transactional email (build summary, qualified, nurture drip).
RESEND_API_KEY=

# --- Booking (Phase 5) ---
# Cal.com white-label link for the "Book a Call" flow.
CAL_COM_LINK=

# --- Analytics (Phase 1+) ---
# PostHog — funnel analysis (configurator drop-off). Public, client-side.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
