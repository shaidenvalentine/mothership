# Mothership — environment variables
# Copy to `.env.local` and fill in. Everything is OPTIONAL — the site builds and
# the forms work (gracefully degrading) without any of these set.

# --- Email / leads (Resend) ---
# Without RESEND_API_KEY, form submissions still succeed and are logged server-side.
RESEND_API_KEY=
# Verified sender (defaults to Resend's onboarding@resend.dev for testing).
RESEND_FROM=
# Where reservation / consultation / newsletter leads are emailed.
LEAD_NOTIFICATION_EMAIL=

# --- Booking (Cal.com) ---
# Public Cal.com link for the discovery-call embed, e.g. "shaiden/discovery-call".
# When unset, the Contact page shows a fallback instead of the embed.
NEXT_PUBLIC_CAL_LINK=
# Public Cal.com link for the demo-van availability calendar (/creators page).
# Same fallback pattern when unset.
NEXT_PUBLIC_CREATOR_CAL_LINK=

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Admin portal: database (Vercel Postgres → Neon) ---
# Without this, the public site still works (forms email) and the admin shows a
# "connect the database" notice. Locally: `vercel env pull .env.local` pulls the
# Vercel-managed Neon vars, then run `pnpm db:push` to create the tables.
DATABASE_URL=
# (Vercel's Neon integration also sets POSTGRES_URL / POSTGRES_PRISMA_URL —
#  any of these is picked up automatically.)

# --- Admin portal: auth (shared password) ---
# The password Shaiden + Brandon use to sign in at /admin (dev fallback:
# "mothership-admin"). ADMIN_SESSION_SECRET signs the session cookie — set a
# long random string in production.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Admin portal: build-tracker photo uploads (Vercel Blob) ---
# Auto-set when you add Blob storage to the Vercel project; needed for uploads.
BLOB_READ_WRITE_TOKEN=

# Public base URL, used to build customer build-tracker links in emails
# (e.g. https://mothershipvans.com). Falls back to the request host if unset.
NEXT_PUBLIC_SITE_URL=

# --- Future phases (not yet wired) ---
# OpenAI lead qualification + n8n CRM sync.
OPENAI_API_KEY=
N8N_WEBHOOK_URL=
